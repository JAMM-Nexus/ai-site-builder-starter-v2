# ─────────────────────────────────────────────
# AI Site Builder v2 — .env приклад
# Цей файл потрібен ТІЛЬКИ для опціональної команди /domain
# (підключення власного домену через Namecheap + Cloudflare API).
#
# Для базового флоу (створення сайту + публікація через git push)
# .env НЕ потрібен — Cloudflare GitHub App деплоїть автоматично.
#
# Якщо тобі потрібен власний домен:
# 1. Скопіюй цей файл як .env (без .example)
# 2. Заповни значення нижче
# 3. .env у .gitignore — у git не потрапить
# ─────────────────────────────────────────────

# Cloudflare API — ТІЛЬКИ для /domain
# dash.cloudflare.com → My Profile → API Tokens → Create Token
# Permissions: Account → Cloudflare Pages → Edit + Zone → DNS → Edit
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Namecheap API — ТІЛЬКИ для /domain якщо домен у Namecheap
# namecheap.com → Profile → Tools → API Access (whitelist твій IP)
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_IP=

# Твій домен (наприклад mysite.com)
DOMAIN=
