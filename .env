# ─────────────────────────────────────────────
# AI Site Builder — credentials
# v3 (multi-project)
#
# Required GLOBAL — used for every project:
#   CLOUDFLARE_API_TOKEN, CLOUDFLARE_ACCOUNT_ID
#
# Per-project settings (cf project name, domain) live inside
#   projects/<slug>/.project.json — NOT in .env.
#
# Optional GLOBAL — only for /domain command:
#   NAMECHEAP_*  (DOMAIN is now per-project, set when you run /domain)
# ─────────────────────────────────────────────

# REQUIRED — Cloudflare (global, one-time setup)
# API token: dash.cloudflare.com → My Profile → API Tokens → Create Token
#            template: "Edit Cloudflare Workers" → check "Cloudflare Pages — Edit"
# Account ID: dash.cloudflare.com → right sidebar of Workers & Pages → Account ID
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ─────────────────────────────────────────────
# OPTIONAL — only fill if you want /domain command (custom domain via Namecheap)
# DOMAIN is set per-project when running /domain — not here.
# ─────────────────────────────────────────────
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_IP=
