# ─────────────────────────────────────────────
# AI Site Builder — credentials
# Required for basic flow (build + deploy):
#   CLOUDFLARE_API_TOKEN, CLOUDFLARE_ACCOUNT_ID, CF_PAGES_PROJECT_NAME
# Optional (only for /domain — connect own custom domain):
#   NAMECHEAP_*, DOMAIN
# ─────────────────────────────────────────────

# REQUIRED — Cloudflare
# API token: dash.cloudflare.com → My Profile → API Tokens → Create Token
#            template: "Edit Cloudflare Workers" → check "Cloudflare Pages — Edit"
# Account ID: dash.cloudflare.com → right sidebar of Workers & Pages → Account ID
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# REQUIRED — Pages project name (Claude generates one when you run /new-site)
# Or pre-fill it manually with kebab-case: my-first-site, cafe-landing, etc.
CF_PAGES_PROJECT_NAME=

# ─────────────────────────────────────────────
# OPTIONAL — only fill if you want /domain command (custom domain via Namecheap)
# ─────────────────────────────────────────────
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_IP=
DOMAIN=
